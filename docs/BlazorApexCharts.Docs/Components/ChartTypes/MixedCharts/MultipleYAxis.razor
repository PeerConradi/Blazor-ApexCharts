                    }
                },
                Tooltip = new()
                {
                    Enabled = true
                }
            },
            new YAxis()
            {
                SeriesName = "Revenue",
                Opposite = true,
                AxisTicks = new()
                {
                    Show = true
                },
                AxisBorder = new()
                {
                    Show = true,
