                    {
                        Colors = "#008FFB"
                    }
                },
                Title = new()
                {
                    Text = "Income (thousand crores)",
                    Style = new()
                    {
                        Color = "#008FFB"
                    }
                },
                Tooltip = new()
                {
                    Enabled = true
                }
            },
            new YAxis()
            {
                SeriesName = "Cashflow",
                Opposite = true,
